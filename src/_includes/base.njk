<!doctype html>
<html lang="de">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <meta name="referrer" content="no-referrer">
  <title>{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }} – {{ site.tagline }}{% endif %}</title>
  <meta name="description" content="{{ description or site.description }}">
  <link rel="canonical" href="{{ site.url }}{{ page.url }}">
  <meta property="og:type" content="website">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:site_name" content="{{ site.name }}">
  <meta property="og:title" content="{% if title %}{{ title }} | {{ site.name }}{% else %}{{ site.name }}{% endif %}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:locale" content="de_DE">
  {%- set ogImg = ogImage or vehicles[0].image %}
  {%- if ogImg %}
  <meta property="og:image" content="{{ ogImg }}">
  {%- if ogImageCard %}
  <meta property="og:image:width" content="1200">
  <meta property="og:image:height" content="630">
  <meta property="og:image:type" content="image/jpeg">
  {%- endif %}
  <meta name="twitter:card" content="summary_large_image">
  {%- endif %}
  <link rel="icon" href="{{ '/assets/favicon.svg' | url }}" type="image/svg+xml">
  <link rel="preconnect" href="https://img.classistatic.de">
  <link rel="preload" as="font" type="font/woff2" href="{{ '/assets/fonts/bricolage-grotesque.woff2' | url }}" crossorigin>
  <link rel="preload" as="font" type="font/woff2" href="{{ '/assets/fonts/manrope.woff2' | url }}" crossorigin>
  {%- if page.url == "/" and vehicles[0].image %}
  <link rel="preload" as="image" href="{{ vehicles[0].image | imgRule(1024) }}" media="(max-width: 860px)" fetchpriority="high">
  <link rel="preload" as="image" href="{{ vehicles[0].image }}" media="(min-width: 861px)" fetchpriority="high">
  {%- elif "/fahrzeuge/" in page.url and lcpImage %}
  <link rel="preload" as="image" href="{{ lcpImage }}" imagesrcset="{{ lcpImage | imgRule(1024) }} 1024w, {{ lcpImage }} 1600w" imagesizes="(max-width: 980px) 94vw, 58vw" fetchpriority="high">
  {%- endif %}
  <link rel="stylesheet" href="{{ '/assets/css/style.css' | url }}">
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "AutoDealer",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "telephone": "{{ site.contact.phone }}",
    "email": "{{ site.contact.email }}",
    "address": {
      "@type": "PostalAddress",
      "streetAddress": "{{ site.contact.street }}",
      "postalCode": "{{ site.contact.zip }}",
      "addressLocality": "{{ site.contact.city }}",
      "addressCountry": "DE"
    },
    "openingHoursSpecification": {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday","Saturday"],
      "opens": "09:00",
      "closes": "17:00"
    },
    "sameAs": ["{{ site.contact.mobileDe }}"],
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "{{ site.reviews.scoreDot }}",
      "bestRating": "5",
      "reviewCount": {{ site.reviews.count }}
    }
  }
  </script>
</head>
<body>
  <a class="skip-link" href="#main">Zum Inhalt springen</a>
  <header class="site-header">
    <div class="container header-inner">
      <a class="brand" href="{{ '/' | url }}">
        <img class="brand-logo" src="{{ '/assets/logo.svg' | url }}" alt="" width="46" height="46">
        <span class="brand-name">Automobile<br><strong>Oststeinbek</strong></span>
      </a>
      <input type="checkbox" id="nav-toggle" class="nav-toggle" aria-hidden="true">
      <label for="nav-toggle" class="nav-toggle-label" aria-label="Menü öffnen">
        <span></span><span></span><span></span>
      </label>
      <nav class="site-nav" aria-label="Hauptnavigation">
        <ul>
          {% for item in site.nav %}
          <li>
            <a href="{{ item.url | url }}"{% if page.url == item.url %} aria-current="page"{% endif %}>{{ item.text }}</a>
          </li>
          {% endfor %}
        </ul>
        <a class="btn btn-sm nav-cta" href="tel:{{ site.contact.phoneHref }}">Anrufen</a>
      </nav>
    </div>
  </header>

  <main id="main">
    {{ content | safe }}
  </main>

  <footer class="site-footer">
    <div class="container footer-grid">
      <div>
        <div class="footer-brand">Automobile Oststeinbek</div>
        <p class="muted">{{ site.tagline }} – seit {{ site.since }} im Osten Hamburgs.</p>
        <a class="rating-line" href="{{ site.reviews.url }}" target="_blank" rel="noopener">
          <span class="stars" aria-hidden="true">★★★★★</span>
          <span>{{ site.reviews.score }} / 5 · {{ site.reviews.count }} Bewertungen auf mobile.de</span>
        </a>
      </div>
      <div>
        <h3>Kontakt</h3>
        <p class="muted">
          {{ site.contact.street }}<br>
          {{ site.contact.zip }} {{ site.contact.city }}<br>
          <a href="tel:{{ site.contact.phoneHref }}">{{ site.contact.phone }}</a><br>
          <a href="tel:{{ site.contact.mobileHref }}">{{ site.contact.mobile }}</a> · <a href="{{ site.contact.whatsapp }}" target="_blank" rel="noopener">WhatsApp</a><br>
          <a href="mailto:{{ site.contact.email }}">{{ site.contact.email }}</a><br>
          Mo–Sa 9–17 Uhr &amp; nach Absprache
        </p>
      </div>
      <div>
        <h3>Rechtliches</h3>
        <ul class="footer-links">
          <li><a href="{{ '/impressum/' | url }}">Impressum</a></li>
          <li><a href="{{ '/datenschutz/' | url }}">Datenschutz</a></li>
        </ul>
      </div>
    </div>
    <div class="container footer-bottom">
      <span class="muted">© {% year %} Automobile Oststeinbek</span> ·
      <a href="https://digitalbau-nord.de" target="_blank" rel="noopener">Website: Digitalbau Nord</a>
    </div>
  </footer>

  <nav class="contact-bar" aria-label="Schnellkontakt">
    <a href="tel:{{ site.contact.phoneHref }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M22 16.9v3a2 2 0 0 1-2.2 2 19.8 19.8 0 0 1-8.6-3.1 19.5 19.5 0 0 1-6-6A19.8 19.8 0 0 1 2.1 4.2 2 2 0 0 1 4.1 2h3a2 2 0 0 1 2 1.7c.1 1 .4 2 .7 2.9a2 2 0 0 1-.5 2.1L8.1 9.9a16 16 0 0 0 6 6l1.2-1.2a2 2 0 0 1 2.1-.5c.9.3 1.9.6 2.9.7a2 2 0 0 1 1.7 2z"/></svg>
      <span>Anrufen</span>
    </a>
    <a href="{{ site.contact.whatsapp }}" target="_blank" rel="noopener">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><path d="M21 11.5a8.5 8.5 0 0 1-12.3 7.6L3 21l1.9-5.7A8.5 8.5 0 1 1 21 11.5z"/></svg>
      <span>WhatsApp</span>
    </a>
    <a href="mailto:{{ site.contact.email }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m22 7-10 6L2 7"/></svg>
      <span>E-Mail</span>
    </a>
  </nav>
</body>
</html>
