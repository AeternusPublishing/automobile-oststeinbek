---
layout: base.njk
pagination:
  data: vehicles
  size: 1
  alias: v
permalink: "/fahrzeuge/{{ (v.slug or v.title) | slugify }}/"
eleventyComputed:
  title: "{{ v.title }}"
  description: "{{ v.title }} bei Automobile Oststeinbek – {{ v.text }}. Jetzt Probefahrt vereinbaren."
  ogImage: "{{ v.image }}"
---
<section class="section-tight">
  <div class="container">
    <p class="crumbs"><a href="{{ '/fahrzeugangebote/' | url }}">← Alle Fahrzeuge</a></p>
    <div class="detail-grid">
      <div>
        <div class="gallery">
          <div class="gallery-main">
            {% if v.images and v.images.length %}
            <img id="gallery-main-img" src="{{ v.images[0] }}" alt="{{ v.title }}" title="Zum Vergrößern klicken">
            <span class="gallery-hint">🔍 Vollbild</span>
            {% else %}
            <div class="thumb" style="aspect-ratio:3/2; display:grid; place-items:center;">Fotos im mobile.de-Inserat</div>
            {% endif %}
          </div>
          {% if v.images and v.images.length > 1 %}
          <div class="gallery-thumbs">
            {% for img in v.images %}
            <button type="button" class="gallery-thumb{% if loop.first %} active{% endif %}" data-src="{{ img }}">
              <img src="{{ img }}" alt="{{ v.title }} – Bild {{ loop.index }}" loading="lazy">
            </button>
            {% endfor %}
          </div>
          {% endif %}
        </div>
        {% if v.description %}
        <div class="detail-desc">
          <h2>Beschreibung</h2>
          {% for para in v.description.split("\n\n") %}{% if para.length < 42 and para == (para | upper) and (para | lower) != para %}<h3 class="desc-h">{{ para }}</h3>{% else %}<p class="muted">{{ para | escape | replace("\n", "<br>") | safe }}</p>{% endif %}{% endfor %}
        </div>
        {% endif %}
      </div>

      <aside class="detail-side">
        {% if v.badge %}<span class="badge">{{ v.badge }}</span>{% endif %}
        <h1 class="detail-title">{{ v.title }}</h1>
        <p class="detail-price">{{ v.price }}</p>
        <p class="muted" style="font-size:.85rem;">{% if "¹" in v.price %}¹ MwSt. ausweisbar. {% endif %}Angaben ohne Gewähr.</p>

        <div class="btn-row" style="margin:1.2rem 0 1.8rem; flex-direction:column; align-items:stretch;">
          <a class="btn" href="tel:{{ site.contact.phoneHref }}">Anrufen: {{ site.contact.phone }}</a>
          <a class="btn btn-whatsapp" href="{{ site.contact.whatsapp }}?text={{ ("Guten Tag, ich interessiere mich für den " + v.title + " (" + v.url + ")") | urlencode }}" target="_blank" rel="noopener">Per WhatsApp anfragen</a>
          <a class="btn btn-outline" href="{{ v.url }}" target="_blank" rel="noopener">Inserat auf mobile.de</a>
        </div>

        {% if v.specs and v.specs.length %}
        <h2 style="font-size:1.15rem;">Fahrzeugdaten</h2>
        <table class="spec-table">
          {% for s in v.specs %}
          <tr><th>{{ s.label }}</th><td>{{ s.value }}</td></tr>
          {% endfor %}
        </table>
        {% endif %}

        {% if v.features and v.features.length %}
        <h2 style="font-size:1.15rem; margin-top:1.6rem;">Ausstattung</h2>
        <ul class="feature-list">
          {% for f in v.features %}<li>{{ f }}</li>{% endfor %}
        </ul>
        {% endif %}
      </aside>
    </div>
  </div>
</section>

<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "Car",
  "name": {{ v.title | dump | safe }},
  "image": {{ (v.images or []) | dump | safe }},
  "offers": {
    "@type": "Offer",
    "priceCurrency": "EUR",
    "price": "{{ v.price | replace('.', '') | replace(' €¹', '') | replace(' €', '') }}",
    "availability": "https://schema.org/InStock",
    "seller": { "@type": "AutoDealer", "name": "{{ site.name }}" }
  }
}
</script>

<div class="lightbox" id="lightbox" hidden>
  <button type="button" class="lb-close" aria-label="Schließen">✕</button>
  <button type="button" class="lb-prev" aria-label="Vorheriges Bild">‹</button>
  <img id="lb-img" src="" alt="{{ v.title }}">
  <button type="button" class="lb-next" aria-label="Nächstes Bild">›</button>
  <span class="lb-count" id="lb-count"></span>
</div>

<script>
(function () {
  var imgs = {{ (v.images or []) | dump | safe }};
  var idx = 0;
  var main = document.getElementById("gallery-main-img");
  var lb = document.getElementById("lightbox");
  var lbImg = document.getElementById("lb-img");
  var lbCount = document.getElementById("lb-count");

  document.querySelectorAll(".gallery-thumb").forEach(function (btn, i) {
    btn.addEventListener("click", function () {
      idx = i;
      main.src = btn.dataset.src;
      document.querySelectorAll(".gallery-thumb").forEach(function (b) { b.classList.remove("active"); });
      btn.classList.add("active");
    });
  });

  function show(i) {
    if (!imgs.length) return;
    idx = (i + imgs.length) % imgs.length;
    lbImg.src = imgs[idx];
    lbCount.textContent = (idx + 1) + " / " + imgs.length;
  }
  function open() { if (!imgs.length) return; lb.hidden = false; document.body.style.overflow = "hidden"; show(idx); }
  function close() { lb.hidden = true; document.body.style.overflow = ""; }

  if (main) main.addEventListener("click", open);
  lb.querySelector(".lb-close").addEventListener("click", close);
  lb.querySelector(".lb-prev").addEventListener("click", function (e) { e.stopPropagation(); show(idx - 1); });
  lb.querySelector(".lb-next").addEventListener("click", function (e) { e.stopPropagation(); show(idx + 1); });
  lb.addEventListener("click", function (e) { if (e.target === lb) close(); });
  document.addEventListener("keydown", function (e) {
    if (lb.hidden) return;
    if (e.key === "Escape") close();
    if (e.key === "ArrowLeft") show(idx - 1);
    if (e.key === "ArrowRight") show(idx + 1);
  });
})();
</script>
